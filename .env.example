# 로컬 API 서버 설정. 이 파일을 복사해 `.env` 로 만들고 값을 채우세요.
# (.env 는 커밋하지 마세요 — 비밀 키가 들어갑니다.)

# 서버 포트 (기본 3001)
PORT=3001

# ── [1] 자동화 컨설팅 받기 (Claude 분석) ──
# https://console.anthropic.com 에서 발급. 없으면 [1]은 비활성, [2] 테스트는 정상 동작.
ANTHROPIC_API_KEY=
# 선택: 사용할 모델 (기본 claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# ── HOME "새 프로젝트 입력" → 시트에 쓰기 ──
# 시트에 연결된 Apps Script 웹앱 URL. 없으면 입력 폼 저장이 비활성.
# 배포 방법: apps-script/README.md
SHEET_WEBAPP_URL=

# ── 아래는 다음 단계(커넥터 배선 시) 사용 — 지금은 비워두어도 됩니다 ──
# Notion 내부 integration 토큰 + 대상 부모 페이지 ID
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=
# Gmail SMTP (앱 비밀번호) + 받는 주소
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=
