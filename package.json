{
  "name": "sheet-hierarchy-homepage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Google Spreadsheet를 데이터베이스로 사용하는 반응형 계층 구조 홈페이지",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run server\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@notionhq/client": "^5.23.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemailer": "^9.0.3"
  }
}
